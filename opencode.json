{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Strix",
      "options": {
        "baseURL": "http://strix.kakushi.lol:8000/v1"
      },
      "models": {
        "qwen35-35b": {
          "name": "qwen35-35b"
        },
        "qwen35-122b": {
          "name": "qwen35-122b"
        }
      }
    }
  },
  "mode": {
    "plan": {
      "temperature": 0.3
    },
    "build": {
      "temperature": 0.6
    },
    "create": {
      "temperature": 0.8
    }
  },
  "mcp": {
    "spec-workflow": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@pimzino/spec-workflow-mcp@latest",
        "/workspaces/fantasy-keiba"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-a7d8e06a-0fde-4a4d-ac35-009ccc8df67b"
      },
      "enabled": true
    }
  }
}
